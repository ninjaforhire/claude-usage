<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.mighty.claude-usage-token-refresh</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/mightydesigncenter/tools/claude-usage/scripts/token_refresh.sh</string>
